{
    // turns inline suggestions off
    "editor.inlineSuggest.enabled": false,
    // turns on clangd code completion
    "clangd.enableCodeCompletion": false,
    "editor.quickSuggestions": {
        "strings": "off",
        "comments": "off",
        "other": "off"
    },
    // turns compact folders off in explorer
    "explorer.compactFolders": false,
    // turns the minimap off
    "editor.minimap.enabled": false,
    // set default dark theme
    "workbench.preferredDarkColorTheme": "Default Dark Modern",
    // set prettier as the default formatter for all languages
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    // enable format on save
    "editor.formatOnSave": true,
    // set the font size
    "editor.fontSize": 16,
    // sets the icon theme to material icon theme
    "workbench.iconTheme": "material-icon-theme",
    // list of words to be considered correct
    "cSpell.words": [
      "appspot",
      "gregwiley",
      "maxlength"
    ]
  }